{
   "action": {
      "default_icon": {
         "128": "icons/icon128.png",
         "16": "icons/icon16.png",
         "48": "icons/icon48.png"
      },
      "default_title": "Cursorfly - Open Source Screen Recorder with Auto Zoom"
   },
   "background": {
      "service_worker": "background.js"
   },
   "description": "Free & open-source screen recorder. Create beautiful recordings with automatic cinematic zoom & pan — 100% offline, no sign-up.",
   "host_permissions": [ "\u003Call_urls>" ],
   "icons": {
      "128": "icons/icon128.png",
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
   },
   "key": "",
   "manifest_version": 3,
   "minimum_chrome_version": "102",
   "name": "Cursorfly - Open Source Screen Recorder with Auto Zoom",
   "permissions": [ "activeTab", "storage", "desktopCapture", "tabs", "scripting" ],
   "update_url": "https://clients2.google.com/service/update2/crx",
   "version": "1.4.0",
   "web_accessible_resources": [ {
      "matches": [ "\u003Call_urls>" ],
      "resources": [ "record.html", "record.js", "editor.html", "editor.js", "zoom-analyzer.js", "video-processor.js", "recorder.js", "content.js" ]
   } ]
}
